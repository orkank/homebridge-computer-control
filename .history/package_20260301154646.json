{
  "name": "homebridge-computer-control",
  "version": "1.0.0",
  "description": "Control your computers (Wake-on-LAN & Sleep) through Apple HomeKit via Homebridge",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "prepublishOnly": "npm run build",
    "build:clients": "bash scripts/build-clients.sh",
    "build:all": "npm run build:clients && npm run build",
    "lint": "eslint src/",
    "dev": "tsc && homebridge -D -P ."
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "wake-on-lan",
    "wol",
    "sleep",
    "computer-control",
    "macos",
    "windows",
    "linux"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "homebridge": ">=1.6.0",
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ping": "^0.4.4",
    "wake_on_lan": "^1.0.0"
  },
  "devDependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.0",
    "@types/node": "^20.10.0",
    "homebridge": "^1.7.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  },
  "homepage": "https://github.com/homebridge-computer-control",
  "repository": {
    "type": "git",
    "url": "https://github.com/homebridge-computer-control.git"
  }
}
