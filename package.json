{
  "name": "homebridge-computer-control",
  "version": "1.1.1",
  "description": "Control your computers (Wake-on-LAN & Sleep) through Apple HomeKit via Homebridge",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm install --include=dev && tsc",
    "watch": "tsc -w",
    "prepublishOnly": "tsc",
    "build:clients": "bash scripts/build-clients.sh",
    "build:all": "npm run build:clients && npm run build",
    "lint": "eslint src/",
    "dev": "tsc && homebridge -D -P ."
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "wake-on-lan",
    "wol",
    "sleep",
    "computer-control",
    "macos",
    "windows",
    "linux"
  ],
  "author": "Orkan Köylü",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orkank/homebridge-computer-control.git"
  },
  "bugs": {
    "url": "https://github.com/orkank/homebridge-computer-control/issues"
  },
  "homepage": "https://github.com/orkank/homebridge-computer-control#readme",
  "files": [
    "dist",
    "config.schema.json",
    "bin",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "homebridge": ">=1.6.0",
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ping": "^0.4.4",
    "wake_on_lan": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.0",
    "@types/node": "^20.10.0",
    "homebridge": "^1.7.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  }
}
